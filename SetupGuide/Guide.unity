      m_Calls: []
  m_text: "Pitch rotation limits : the limits of the rotation on the x-axis.\nPitch
    rotation limits : the limits of the rotation on the y-axis.\nMin angle value
    : the minimum allowed rotation of the camera between -180\xB0 and maxAngleValue.\nMax
    angle value : The maximus allowedrotation of the camera between minAngleValue
    and 180\xB0.\nWrap : How the camera should behave when reaching a limit. If true
    goes to the opposite limits and take from here, else stays at the reached limit."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
